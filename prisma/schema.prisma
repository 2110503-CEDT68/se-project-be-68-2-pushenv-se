generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  jobSeeker
  systemAdmin
  companyUser
}

enum JobType {
  full_time
  part_time
  internship
  contract
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @db.VarChar(255)
  email              String              @unique @db.VarChar(255)
  passwordHash       String              @map("password_hash") @db.VarChar(255)
  role               Role
  phone              String?             @db.VarChar(20)
  avatar             String?             @db.VarChar(500)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  companyProfile     CompanyProfile?
  createdEvents      Event[]             @relation("EventCreator")
  eventRegistrations EventRegistration[]

  @@map("users")
}

model CompanyProfile {
  id            String         @id @default(uuid()) @db.Uuid
  companyUserId String         @unique @map("companyUser_id") @db.Uuid
  description   String?
  logo          String?        @db.VarChar(500)
  website       String?        @db.VarChar(500)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  companyUser   User           @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  eventLinks    EventCompany[]
  jobs          JobListing[]

  @@map("company_profiles")
}

model Event {
  id            String              @id @default(uuid()) @db.Uuid
  name          String              @db.VarChar(255)
  description   String
  location      String              @db.VarChar(255)
  startDate     DateTime            @map("start_date") @db.Date
  endDate       DateTime            @map("end_date") @db.Date
  banner        String?             @db.VarChar(500)
  isPublished   Boolean             @default(false) @map("is_published")
  createdBy     String              @map("created_by") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  systemAdmin   User                @relation("EventCreator", fields: [createdBy], references: [id])
  companies     EventCompany[]
  registrations EventRegistration[]

  @@map("events")
}

model EventCompany {
  eventId   String         @map("event_id") @db.Uuid
  companyId String         @map("company_id") @db.Uuid
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([eventId, companyId])
  @@map("event_companies")
}

model EventRegistration {
  id           String   @id @default(uuid()) @db.Uuid
  eventId      String   @map("event_id") @db.Uuid
  jobSeekerId  String   @map("jobSeeker_id") @db.Uuid
  registeredAt DateTime @default(now()) @map("registered_at") @db.Timestamptz(6)
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  jobSeeker    User     @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  @@unique([eventId, jobSeekerId])
  @@map("event_registrations")
}

model JobListing {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @map("company_id") @db.Uuid
  title          String         @db.VarChar(255)
  type           JobType
  location       String         @db.VarChar(255)
  description    String
  requirements   String?
  qualifications String?
  salary         String?        @db.VarChar(100)
  attachment     String?        @db.VarChar(500)
  isClosed       Boolean        @default(false) @map("is_closed")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  company        CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("job_listings")
}
