PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_fair

# Explicitly set Postgres credentials to override global OS variables during local dev
POSTGRES_USER=postgres
DB_PASSWORD=postgres
POSTGRES_DB=job_fair
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:3000

# Seeding Passwords/Emails
SEED_ADMIN_EMAIL=admin@jobfair.com
SEED_ADMIN_PASSWORD=admin123
SEED_COMPANY_PASSWORD=company123
SEED_JOBSEEKER_PASSWORD=password123

# Docker-only: Internal backend URL (uses service name 'backend')
# For local development, this is not needed as BASE_URL defaults to localhost
BACKEND_URL=http://backend:4000
